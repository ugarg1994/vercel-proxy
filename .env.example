# CTIX API proxy – set these in Vercel Project Settings → Environment Variables
# Required for the proxy to sign and forward requests to CTIX.

# Base URL of your CTIX instance (no trailing slash), e.g. https://demov6.cyware.com/ctixapi
# Then /api/ping → https://demov6.cyware.com/ctixapi/ping
CTIX_API_URL=

# Access ID (public key) from CTIX Open API configuration
CTIX_ACCESS_ID=

# Secret key (private key) from CTIX Open API configuration
CTIX_SECRET_KEY=

# Optional: API version (default v3), added as query param if not in request
# CTIX_API_VERSION=v3
